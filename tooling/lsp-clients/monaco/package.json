{
  "name": "@kson/monaco-editor",
  "//": "[[kson-version-num]]",
  "version": "0.3.0-dev.0",
  "description": "Monaco editor with KSON language support and LSP integration",
  "type": "module",
  "main": "./dist/kson-monaco.js",
  "module": "./dist/kson-monaco.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/kson-monaco.js",
      "default": "./dist/kson-monaco.js"
    }
  },
  "files": [
    "dist",
    "dist-iframe",
    "readme.md"
  ],
  "scripts": {
    "dev": "vite",
    "compile:types": "tsc -p tsconfig.json",
    "build": "vite build && npm run compile:types",
    "preview": "vite preview",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:headed": "playwright test --headed",
    "build:iframe": "vite build --config vite.iframe.config.ts && vite build --config vite.iframe-client.config.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@kson/lsp-shared": "file:../shared"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.50.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "happy-dom": "^20.8.4",
    "monaco-editor": "^0.52.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
